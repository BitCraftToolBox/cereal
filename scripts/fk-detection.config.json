  "typeConditionalRules": [
    {
      "discriminatorType": "ItemType",
      "siblingSuffix": {"from": "_type", "to": "_id"},
      "conditions": [
        {"whenValue": "Item", "targetTable": "item_desc"},
        {"whenValue": "Cargo", "targetTable": "cargo_desc"}
      ]
    },
    {
      "discriminatorType": "EntityType",
      "discriminatorLeaf": "entity_type",
      "siblingLeaf": "description_id",
      "conditions": [
        {"whenValue": "Building", "targetTable": "building_desc"},
        {"whenValue": "Enemy", "targetTable": "enemy_desc"},
        {"whenValue": "Npc", "targetTable": "npc_desc"},
        {"whenValue": "Resource", "targetTable": "resource_desc"},
        {"whenValue": "Player", "targetTable": "player_state"},
        {"whenValue": "None", "targetTable": null}
      ]
    },
    {
      "discriminatorType": "EntityType",
      "siblingSuffix": {"from": "_type", "to": "_entity_id"},
      "conditions": [
        {"whenValue": "Building", "targetTable": "building_state"},
        {"whenValue": "Enemy", "targetTable": "enemy_state"},
        {"whenValue": "Npc", "targetTable": "npc_state"},
        {"whenValue": "Resource", "targetTable": "resource_state"},
        {"whenValue": "Player", "targetTable": "player_state"},
        {"whenValue": "None", "targetTable": null}
      ]
    },
    {
      "discriminatorType": "PlayerActionType",
      "discriminatorLeaf": "action_type",
      "sibling_leaf": "recipe_id",
      "conditions": [
        {"whenValue": "Attack", "targetTable": "combat_action_desc"},
        {"whenValue": "Extract", "targetTable": "extraction_recipe_desc"},
        {"whenValue": "Build", "targetTable": "construction_recipe_desc"},
        {"whenValue": "Deconstruct", "targetTable": "deconstruction_recipe_desc"},
        {"whenValue": "Terraform", "targetTable": "terraform_recipe_desc"},
        {"whenValue": "Craft", "targetTable": "crafting_recipe_desc"},
        {"whenValue": "ConvertItems", "targetTable": "item_conversion_recipe_desc"},
        {"whenValue": "PlacePlaceable", "targetTable": "placeable_placement_desc"},
        {"whenValue": "InteractPlaceable", "targetTable": "placeable_interaction_desc"}
      ]
    },
    {
      "discriminatorType": "PlayerActionType",
      "discriminatorLeaf": "action_type",
      "sibling_leaf": "target_id",
      "conditions": [
        {"whenValue": "Attack", "targetTable": "enemy_state"},
        {"whenValue": "Extract", "targetTable": "resource_state"},
        {"whenValue": "PaveTile", "targetTable": "paving_tile_desc"},
        {"whenValue": "Build", "targetTable": "project_site_state"},
        {"whenValue": "Deconstruct", "targetTable": "building_state"},
        {"whenValue": "RepairBuilding", "targetTable": "building_state"},
        {"whenValue": "ResupplyClaim", "targetTable": "building_state"},
        {"whenValue": "Terraform", "targetTable": "building_state"},
        {"whenValue": "DeployDeployable", "targetTable": "deployable_desc"},
        {"whenValue": "StoreDeployable", "targetTable": "deployable_state"},
        {"whenValue": "Climb", "targetTable": "location_state"},
        {"whenValue": "Craft", "targetTable": "building_state"},
        {"whenValue": "ResupplyEmpireNode", "targetTable": "building_state"},
        {"whenValue": "UseElevator", "targetTable": "building_state"},
        {"whenValue": "PlacePillarShaping", "targetTable": "pillar_shaping_desc"},
        {"whenValue": "DestroyPillarShaping", "targetTable": "location_state"},
        {"whenValue": "InteractPlaceable", "targetTable": "placeable_state"}
      ]
    }
